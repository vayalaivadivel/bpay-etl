FROM apache/hop:2.15.0

##########################################################
# ROOT USER
##########################################################

USER root

##########################################################
# INSTALL REQUIRED PACKAGES
##########################################################

RUN apk add --no-cache \
    curl \
    bash \
    busybox \
    tzdata

##########################################################
# WORK DIRECTORY
##########################################################

WORKDIR /files

##########################################################
# COPY PROJECT FILES
##########################################################

COPY workflows/ /files/workflows/
COPY pipelines/ /files/pipelines/
COPY jdbc/ /files/jdbc/
COPY config/ /files/config/
COPY scripts/ /files/scripts/

##########################################################
# SCRIPT PERMISSIONS
##########################################################

RUN chmod +x /files/scripts/*.sh || true

##########################################################
# APACHE HOP ENVIRONMENT
##########################################################

ENV HOP_SERVER_PORT=8080
ENV HOP_SERVER_HOSTNAME=0.0.0.0
ENV HOP_LOG_LEVEL=Basic

##########################################################
# JAVA OPTIONS
##########################################################

ENV JAVA_OPTS="-Xms512m -Xmx1024m"

##########################################################
# TIMEZONE
##########################################################

ENV TZ=Asia/Kolkata

##########################################################
# EXPOSE PORTS
##########################################################

EXPOSE 8080
EXPOSE 8081

##########################################################
# HEALTHCHECK (Docker)
##########################################################

HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 \
CMD curl -fs http://localhost:8081/ || exit 1

##########################################################
# START SCRIPT
##########################################################

ENTRYPOINT ["/files/scripts/start.sh"]